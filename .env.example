# GitHub token must stay server-side. Do not prefix with NEXT_PUBLIC_.
# Fine-grained PAT permissions: target repo -> Issues: Read and write.
GITHUB_TOKEN=<server-side-github-token>
GITHUB_OWNER=georgewangyu
GITHUB_REPO=audience-request-form
GITHUB_PRIVATE_REPO=audience-private-intake

# Optional. Defaults are safe for the simple prototype.
GITHUB_API_VERSION=2022-11-28
REQUEST_FORM_ALLOWED_ORIGIN=
